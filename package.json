{
  "name": "@cruglobal/js-hcl2",
  "version": "0.0.0",
  "description": "Parse and encode HashiCorp Configuration Language v2 (HCL2) in TypeScript, with lossless round-trip support.",
  "keywords": [
    "hcl",
    "hcl2",
    "hashicorp",
    "terraform",
    "parser",
    "encoder",
    "stringify"
  ],
  "homepage": "https://github.com/CruGlobal/js-hcl2#readme",
  "bugs": {
    "url": "https://github.com/CruGlobal/js-hcl2/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CruGlobal/js-hcl2.git"
  },
  "license": "BSD-3-Clause",
  "author": "Cru",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICES.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "generate:unicode": "node scripts/generate-unicode.mjs"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "fast-check": "^4.7.0",
    "happy-dom": "^20.9.0",
    "hcl2-json-parser": "^1.0.1",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
