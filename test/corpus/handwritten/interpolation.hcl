simple   = "hello ${name}"
nested   = "${foo[bar.baz]}"
object_interp = "${ { k = 1 }.k }"
strip    = "${~ x ~}"
multiple = "${a}-${b}-${c}"
escape   = "literal $${interp} and %%{directive}"
directive_if = "%{if enabled}on%{else}off%{endif}"
directive_for = "%{for k, v in map}${k}=${v};%{endfor}"
mixed_template = "pre %{if a}yes${b}%{endif} post"
